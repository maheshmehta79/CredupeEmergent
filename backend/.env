# ─── Core ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_PREFIX=api/v1

# ─── Database — local Postgres (dev) or Cloudflare Hyperdrive (prod) ────────
# Local dev (current value):
DATABASE_URL=postgresql://credupe:credupe_dev@127.0.0.1:5432/credupe?schema=public
# Production via Cloudflare Hyperdrive → hosted Postgres (Neon / Supabase / RDS):
#   1. Create a Hyperdrive config: https://developers.cloudflare.com/hyperdrive/
#   2. It returns a connection string like:
#      postgresql://<user>:<password>@<hyperdrive-endpoint>/<db>?sslmode=require
#   3. Paste it as DATABASE_URL and restart. No schema changes — Prisma is transparent.

# ─── Cache / queues ─────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ─── Auth ───────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_development_only
JWT_ACCESS_TTL=900
JWT_REFRESH_SECRET=change_me_refresh_secret_development_only
JWT_REFRESH_TTL=2592000
BCRYPT_SALT_ROUNDS=10

# ─── Seeded Admin ───────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@credupe.local
SEED_ADMIN_PASSWORD=Admin@12345

# ─── Object storage (S3-compatible — AWS S3 or Cloudflare R2) ───────────────
# StorageService auto-detects real creds; unset → mocked upload URLs.
# For Cloudflare R2, use:
#   S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
#   S3_REGION=auto
#   S3_BUCKET=credupe-documents
#   S3_ACCESS_KEY_ID=<R2 access key ID>
#   S3_SECRET_ACCESS_KEY=<R2 secret>
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=credupe-documents
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ─── Notification providers — mocked if unset ───────────────────────────────
SMS_PROVIDER_API_KEY=
EMAIL_PROVIDER_API_KEY=
EMAIL_FROM=no-reply@credupe.local

# ─── Rate limiting ──────────────────────────────────────────────────────────
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=120

# ─── CORS ───────────────────────────────────────────────────────────────────
CORS_ORIGINS=*
